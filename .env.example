# Copy this file to .env and adjust the values for your machine.

ROUNDTABLE_PORT=8787
ROUNDTABLE_CHECKIN_ENABLED=true

# Speaker instruction templates. These files are included in the repo and can
# be edited to fit your own Codex / Claude Roundtable behavior.
ROUNDTABLE_CODEX_INSTRUCTIONS_FILE=templates/roundtable-codex-instructions.md
ROUNDTABLE_CLAUDE_INSTRUCTIONS_FILE=templates/roundtable-claude-instructions.md

# Optional local CLI paths. On Windows, absolute .cmd paths avoid PATH issues
# when Roundtable is launched by a desktop app or background process.
ROUNDTABLE_CODEX_COMMAND=%APPDATA%\npm\codex.cmd
ROUNDTABLE_CLAUDE_COMMAND=%APPDATA%\npm\claude.cmd

# Runtime turns can legitimately take a while on large coding tasks. The start
# timeout catches cases where the runtime never accepts the turn; the turn
# timeout applies after work starts.
ROUNDTABLE_TURN_START_TIMEOUT_MS=240000
ROUNDTABLE_TURN_TIMEOUT_MS=1800000

# Optional provider keys. Keep real keys in .env only.
DEEPSEEK_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional voice output for [VOICE] messages.
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_CODEX=your_codex_voice_id_here
ELEVENLABS_VOICE_CLAUDE=your_claude_voice_id_here
